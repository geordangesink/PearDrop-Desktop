{
  "name": "pear-drops-desktop",
  "productName": "PearDrop",
  "version": "0.3.1",
  "upgrade": "pear://za3e8sw9mpqjah8uricsbpqmnsq5egcfc9jte4kcj38y7hwgdbay",
  "description": "Native-first desktop uploader/downloader for PearDrop",
  "license": "Apache-2.0",
  "author": "",
  "type": "commonjs",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "lint": "prettier --check . && lunte",
    "format": "prettier --write . && lunte --fix",
    "icons:sync": "./scripts/sync-icons.sh",
    "start": "electron-forge start -- --no-updates",
    "start:prod-relay": "PEARDROPS_RELAY_URL=wss://pear-drops.up.railway.app electron-forge start -- --no-updates",
    "prepackage": "npm run icons:sync",
    "package": "electron-forge package",
    "premake:darwin": "npm run icons:sync",
    "make:darwin": "electron-forge make --platform=darwin",
    "premake:darwin:builder": "npm run icons:sync",
    "make:darwin:builder": "electron-builder --mac dmg --arm64 --publish never",
    "premake:mas": "npm run icons:sync",
    "make:mas": "test -n \"$MAS_PROVISIONING_PROFILE\" || { echo \"MAS_PROVISIONING_PROFILE is required\"; exit 1; }; test -n \"$MAC_CODESIGN_IDENTITY\" || { echo \"MAC_CODESIGN_IDENTITY is required\"; exit 1; }; test -n \"$MAC_INSTALLER_IDENTITY\" || { echo \"MAC_INSTALLER_IDENTITY is required\"; exit 1; }; APP_IDENTITY=\"$MAC_CODESIGN_IDENTITY\"; APP_IDENTITY=\"${APP_IDENTITY#3rd Party Mac Developer Application: }\"; INSTALLER_IDENTITY=\"$MAC_INSTALLER_IDENTITY\"; INSTALLER_IDENTITY=\"${INSTALLER_IDENTITY#3rd Party Mac Developer Installer: }\"; CSC_IDENTITY_AUTO_DISCOVERY=false SKIP_MANUAL_MAC_SIGN=1 electron-builder --mac mas --arm64 --publish never -c.mac.identity=\"$APP_IDENTITY\" -c.mas.identity=\"$APP_IDENTITY\" -c.pkg.identity=\"$INSTALLER_IDENTITY\" -c.mas.provisioningProfile=\"$MAS_PROVISIONING_PROFILE\"",
    "make:win32": "electron-forge make --platform=win32",
    "make:win32:squirrel": "electron-forge make --platform=win32 --targets @electron-forge/maker-squirrel",
    "make:linux": "electron-forge package && ./scripts/build-app-image.sh",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "@hyperswarm/dht-relay": "^0.4.3",
    "bare-path": "^3.0.0",
    "bare-rpc": "^1.1.0",
    "corestore": "^7.9.1",
    "hyperswarm": "^4.17.0",
    "paparam": "^1.10.0",
    "pear-drop-core": "^0.4.1",
    "pear-runtime": "^1.0.1",
    "which-runtime": "^1.3.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-msix": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "app-builder-lib": "^26.8.1",
    "electron": "^40.2.1",
    "electron-builder": "^26.0.12",
    "electron-forge-plugin-prune-prebuilds": "^1.0.0",
    "electron-forge-plugin-universal-prebuilds": "^1.0.0",
    "hyperdht": "^6.19.1",
    "lunte": "^1.6.0",
    "prettier": "^3.8.1",
    "prettier-config-holepunch": "^2.0.0"
  },
  "build": {
    "appId": "online.peardrop.app",
    "productName": "PearDrop",
    "directories": {
      "output": "out/make"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "workers/**/*",
      "build/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/*.bare",
      "**/*.dylib"
    ],
    "afterSign": "scripts/mac-sign-after-pack.cjs",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ],
      "identity": "${env.MAC_CODESIGN_IDENTITY}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "mas": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "identity": "${env.MAC_CODESIGN_IDENTITY}",
      "hardenedRuntime": false,
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "provisioningProfile": "${env.MAS_PROVISIONING_PROFILE}"
    },
    "pkg": {
      "installLocation": "/Applications",
      "identity": "${env.MAC_INSTALLER_IDENTITY}"
    },
    "dmg": {
      "sign": false,
      "icon": "build/installer-drive.icns",
      "title": "PearDrop Installer",
      "iconSize": 112,
      "window": {
        "width": 658,
        "height": 498
      }
    }
  }
}
